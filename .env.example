# =============================================================================
# AMA-RT .env.example  (Phase 1 - Safety Foundation)
# =============================================================================
#
# IMPORTANT
# ---------
# This file MUST NEVER contain real API keys, real secrets, or real
# credentials. The repository's .gitignore is configured to ignore the real
# `.env` file. Phase 1 is paper-only and DOES NOT consume any of the
# exchange / Telegram / LLM credentials below; they are listed only as
# placeholders for future phases (Issues #2 - #10).
#
# Phase 1 hard-coded safety defaults:
#   - trading_mode = paper
#   - live_trading_enabled = false
#   - right_tail_enabled = false
#   - llm_enabled = false
#   - exchange_live_order_enabled = false
#
# Even if a malicious or accidental value is supplied below, the Phase 1 code
# in app/config/settings.py + app/risk/engine.py will refuse to enable live
# trading. Real exchange / Telegram / LLM clients are NOT implemented in
# Phase 1; they are skeleton-only.
# =============================================================================

# ---- Runtime mode ----------------------------------------------------------
# Allowed: paper | live_limited | live
# Phase 1 ALWAYS coerces this to "paper" regardless of value.
AMA_TRADING_MODE=paper
AMA_LIVE_TRADING_ENABLED=false
AMA_RIGHT_TAIL_ENABLED=false
AMA_LLM_ENABLED=false
AMA_EXCHANGE_LIVE_ORDER_ENABLED=false

# ---- Logging ---------------------------------------------------------------
AMA_LOG_LEVEL=INFO

# ---- Database --------------------------------------------------------------
# Directory where SQLite WAL databases are stored.
AMA_DATA_DIR=./data

# ---- Exchange (placeholders only, NOT consumed in Phase 1) -----------------
# Phase 1 does NOT instantiate any exchange client. These keys are listed so
# future phases have a documented contract. Leave blank for Phase 1.
AMA_EXCHANGE_NAME=binance
AMA_EXCHANGE_API_KEY=
AMA_EXCHANGE_API_SECRET=

# ---- Telegram (placeholders only, NOT consumed in Phase 1) -----------------
AMA_TELEGRAM_BOT_TOKEN=
AMA_TELEGRAM_ADMIN_CHAT_IDS=

# ---- LLM / DeepSeek (placeholders only, NOT consumed in Phase 1) -----------
AMA_DEEPSEEK_API_KEY=


# =============================================================================
# PR111 - Live API Integration Pack v0 (Binance / Telegram / DeepSeek)
# =============================================================================
#
# PR111 is the FIRST PR allowed to hold real API credentials and to talk to
# the real Binance private-read / Telegram / DeepSeek APIs. It does NOT place
# any real order, does NOT change leverage/margin, and keeps the order path
# BLOCKED (LIVE_SHADOW). Leave these blank to run a pure read-only / paper
# session.
#
# NEVER put a real secret in this example file. Real secrets belong in a
# local `.env` (gitignored) or your secrets manager.
#
# A missing secret NEVER crashes the system; the health check reports
# API_HEALTH_MISSING_SECRET. Only masked secrets (abc***xyz) ever surface.
# -----------------------------------------------------------------------------

# ---- Live runtime mode (default LIVE_SHADOW) -------------------------------
# Allowed: PAPER | LIVE_SHADOW | LIVE_LIMITED | LIVE_FULL
# PR111 NEVER auto-escalates above LIVE_SHADOW; LIVE_LIMITED / LIVE_FULL are
# coerced back to LIVE_SHADOW until a later live-capital PR.
AMA_LIVE_RUNTIME_MODE=LIVE_SHADOW
AMA_LIVE_API_HEALTHCHECK_ENABLED=true
# MUST stay false in normal use. PR111/PR112 never log a raw secret regardless.
# This key MUST exist in your .env.live; the PR112 env validator warns
# (ENV_SECRET_LOGGING_KEY_MISSING) if it is absent.
AMA_SECRET_LOGGING_ALLOWED=false

# ---- Capital profile (PR112) -----------------------------------------------
# The active capital profile id from the PR110 ladder (L0_SHADOW ..
# L8_10M_CAPITAL_PRESERVATION). PR112 enforces the 10U small-capital posture
# L1_10U_PROBE. Both names are supported; AMA_LIVE_CAPITAL_PROFILE_ID takes
# priority over AMA_LIVE_CAPITAL_PROFILE when both are set. An invalid value
# surfaces CONFIG_INVALID_CAPITAL_PROFILE (never a silent fallback). Default
# is L0_SHADOW (no real orders). PR112 never auto-escalates the profile.
AMA_LIVE_CAPITAL_PROFILE=L0_SHADOW
# AMA_LIVE_CAPITAL_PROFILE_ID=L1_10U_PROBE

# ---- Binance live API ------------------------------------------------------
# Recommended: a key WITHOUT withdraw permission. PR111 never requires
# withdraw; if the key has it, the health check raises a high-risk warning.
#
# Placeholder values such as PUT_YOUR_KEY_HERE / PUT_YOUR_SECRET_HERE are
# DETECTED before any real HTTP call: the health check returns
# PLACEHOLDER_SECRET_CONFIGURED (not an HTTP 401). Replace them with your real
# values in a local .env / .env.live (never commit real secrets).
AMA_BINANCE_API_KEY=
AMA_BINANCE_API_SECRET=
AMA_BINANCE_BASE_URL=https://api.binance.com
AMA_BINANCE_FAPI_BASE_URL=https://fapi.binance.com
AMA_BINANCE_ENABLE_PRIVATE_READ=false
# PR111/PR112 keep the order path blocked even if this is true.
AMA_BINANCE_ENABLE_PRIVATE_TRADE=false
AMA_BINANCE_USE_TESTNET=false

# ---- Telegram bot live API -------------------------------------------------
AMA_TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids allowed to receive operator messages.
AMA_TELEGRAM_ALLOWED_CHAT_IDS=
# Real outbound is OFF by default. A test message is only sent when outbound
# is enabled AND the operator explicitly passes --send-telegram-test.
AMA_TELEGRAM_OUTBOUND_ENABLED=false

# ---- DeepSeek live API (MARKET_INTELLIGENCE_ONLY) --------------------------
# DeepSeek can never decide direction / size / leverage / stop / target /
# execution. ai_trade_authority is always false.
AMA_DEEPSEEK_API_KEY=
AMA_DEEPSEEK_BASE_URL=https://api.deepseek.com
AMA_DEEPSEEK_MODEL=deepseek-chat
AMA_DEEPSEEK_ENABLED=false
